{
  "manifest_version": 3,
  "name": "Walmart Order Split Calculation",
  "version": "1.0.0",
  "description": "Calculates proportional tax and tip for shared Walmart orders instantly without a spreadsheet.",
  "action": {
    "default_title": "Extract Walmart Order"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.walmart.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'none'; frame-ancestors 'none'"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-DQ0WArMw.js"
      ],
      "matches": [
        "https://*.walmart.com/orders/*",
        "https://www.walmart.com/orders/*",
        "https://*.walmart.com/account/purchase-history*"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "public/icon-16.png",
    "32": "public/icon-32.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://*.walmart.com/account/purchase-history*",
        "https://*.walmart.com/orders/*",
        "https://www.walmart.com/orders/*"
      ],
      "resources": [
        "index.html",
        "assets/*"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://*.walmart.com/*",
        "https://*.walmart.com/*",
        "https://www.walmart.com/*"
      ],
      "resources": [
        "assets/content.ts-DQ0WArMw.js"
      ],
      "use_dynamic_url": false
    }
  ]
}

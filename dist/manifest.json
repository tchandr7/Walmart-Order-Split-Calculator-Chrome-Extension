{
  "manifest_version": 3,
  "name": "Walmart Order Split Calculation",
  "version": "1.0.0",
  "description": "Calculates proportional tax and tip for shared Walmart orders instantly without a spreadsheet.",
  "action": {
    "default_title": "Extract Walmart Order"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.walmart.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-C_OYaYb1.js"
      ],
      "matches": [
        "https://*.walmart.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "public/icon-16.png",
    "32": "public/icon-32.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://*.walmart.com/*"
      ],
      "resources": [
        "index.html",
        "assets/*",
        "assets/content.ts-C_OYaYb1.js"
      ],
      "use_dynamic_url": false
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Walmart Order Split Calculation",
  "version": "1.0.0",
  "description": "Calculates proportional tax and tip for shared Walmart orders instantly without a spreadsheet.",
  "action": {
    "default_title": "Extract Walmart Order"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.walmart.com/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.walmart.com/*"
      ],
      "js": [
        "src/content.ts"
      ]
    }
  ],
  "icons": {
    "16": "public/icon-16.png",
    "32": "public/icon-32.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.walmart.com/*",
        "<all_urls>"
      ],
      "resources": [
        "index.html",
        "assets/*"
      ]
    }
  ]
}